<div class="my-5" data-controller="tag-input" data-tag-input-url-value="<%= tags_path(format: :json) %>" data-tag-input-field-name-value="<%= field_name %>">
  <label class="block text-sm font-medium text-gray-700 mb-1"><%= label %></label>
  <div class="flex flex-wrap gap-2 mt-2 mb-2" data-tag-input-target="tags">
    <% current_tags.each do |tag_name| %>
      <span class="inline-flex items-center gap-1 bg-gray-200 text-gray-700 px-2 py-1 rounded-md text-sm" data-tag-input-target="tag">
        <%= tag_name %>
        <input type="hidden" name="<%= field_name %>" value="<%= tag_name %>">
        <button type="button" data-action="tag-input#removeTag" class="text-gray-500 hover:text-gray-800 cursor-pointer">&times;</button>
      </span>
    <% end %>
  </div>
  <div class="relative">
    <input type="text" data-tag-input-target="input" data-action="input->tag-input#suggest keydown->tag-input#keydown"
           placeholder="<%= placeholder %>" autocomplete="off"
           class="block shadow-sm rounded-md border border-gray-400 px-3 py-2 w-full focus:outline-gray-600" />
    <ul data-tag-input-target="suggestions" class="hidden absolute z-10 w-full bg-white border border-gray-300 rounded-md mt-1 shadow-lg max-h-40 overflow-y-auto"></ul>
  </div>
</div>
