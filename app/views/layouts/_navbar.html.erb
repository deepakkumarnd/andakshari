<nav class="fixed top-0 left-0 right-0 z-50 bg-white border-b border-gray-100 px-5 py-3">
  <div class="flex justify-between items-center">
    <div class="flex-1"></div>
    <%= link_to root_path, class: "inline-flex flex-col leading-tight" do %>
      <span class="text-4xl font-bold text-primary font-logo">അന്താക്ഷരി</span>
    <% end %>
    <div class="flex-1 flex items-center gap-1 justify-end">
      <% if user_signed_in? %>
        <%= link_to new_game_room_path, class: "p-2 rounded-full hover:bg-gray-100 text-gray-500", title: "Start a game" do %>
          <%= image_tag "gamepad.svg", class: "w-5 h-5", alt: "Play" %>
        <% end %>
        <% if current_user.admin? %>
          <%= link_to admin_dashboard_path, class: "p-2 rounded-full hover:bg-gray-100 text-gray-500", title: "Admin dashboard" do %>
            <%= image_tag "squares.svg", class: "w-5 h-5", alt: "Admin" %>
          <% end %>
        <% end %>
        <%= render "layouts/notification_bell", notifications: @notifications %>

        <%# Sign out icon %>
        <%= button_to destroy_user_session_path, method: :delete,
              class: "p-2 rounded-full hover:bg-gray-100 text-gray-500 cursor-pointer",
              title: "Sign out",
              form: { "data-turbo": "false" } do %>
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0013.5 3h-6a2.25 2.25 0 00-2.25 2.25v13.5A2.25 2.25 0 007.5 21h6a2.25 2.25 0 002.25-2.25V15M12 9l-3 3m0 0l3 3m-3-3h12.75" />
          </svg>
        <% end %>
      <% else %>
        <%= link_to "Sign in", new_user_session_path,
            class: "rounded-md px-3 py-1.5 bg-gray-700 hover:bg-gray-600 text-white font-medium text-sm" %>
      <% end %>
    </div>
  </div>
</nav>
