<% content_for :title, "Admin Dashboard" %>

<div class="max-w-5xl w-full">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold text-heading">Admin Dashboard</h1>
    <%= link_to "Search logs →", admin_search_logs_path, class: "text-sm text-gray-500 hover:text-gray-800" %>
  </div>

  <%# Stats cards %>
  <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-10">
    <div class="border border-border rounded-xl p-4 bg-gray-50">
      <p class="text-xs text-gray-500 uppercase tracking-wide mb-1">Songs</p>
      <p class="text-3xl font-bold text-heading"><%= @stats[:songs] %></p>
    </div>
    <div class="border border-border rounded-xl p-4 bg-gray-50">
      <p class="text-xs text-gray-500 uppercase tracking-wide mb-1">Users</p>
      <p class="text-3xl font-bold text-heading"><%= @stats[:users] %></p>
    </div>
    <div class="border border-border rounded-xl p-4 bg-gray-50">
      <p class="text-xs text-gray-500 uppercase tracking-wide mb-1">Pending Edits</p>
      <p class="text-3xl font-bold <%= @stats[:pending_edits] > 0 ? 'text-amber-600' : 'text-heading' %>"><%= @stats[:pending_edits] %></p>
    </div>
    <div class="border border-border rounded-xl p-4 bg-gray-50">
      <p class="text-xs text-gray-500 uppercase tracking-wide mb-1">Total Likes</p>
      <p class="text-3xl font-bold text-heading"><%= @stats[:likes] %></p>
    </div>
  </div>

  <div class="grid md:grid-cols-2 gap-8">
    <%# Pending edit suggestions %>
    <div>
      <h2 class="text-base font-semibold text-heading mb-3">Pending Edit Suggestions</h2>
      <% if @pending_edit_logs.any? %>
        <div class="divide-y divide-border border border-border rounded-xl overflow-hidden">
          <% @pending_edit_logs.each do |edit_log| %>
            <div class="px-4 py-3 bg-white flex items-start justify-between gap-3">
              <div class="min-w-0">
                <p class="text-sm font-medium text-heading truncate">
                  <%= link_to edit_log.song.start_letter, song_path(edit_log.song), class: "hover:underline" %>
                  <span class="text-gray-400 font-normal">·</span>
                  <span class="text-amber-700"><%= edit_log.field %></span>
                </p>
                <p class="text-xs text-gray-500 mt-0.5"><%= edit_log.user.username %> · <%= time_ago_in_words(edit_log.created_at) %> ago</p>
              </div>
              <%= link_to "Review →", song_edit_log_path(edit_log.song, edit_log), class: "text-xs text-gray-600 hover:text-gray-900 shrink-0" %>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="text-sm text-gray-400">No pending edit suggestions.</p>
      <% end %>
    </div>

    <%# Recent users %>
    <div>
      <h2 class="text-base font-semibold text-heading mb-3">Recent Users</h2>
      <div class="divide-y divide-border border border-border rounded-xl overflow-hidden">
        <% @recent_users.each do |user| %>
          <div class="px-4 py-3 bg-white flex items-center justify-between gap-3">
            <div class="min-w-0">
              <p class="text-sm font-medium text-heading truncate"><%= user.username %></p>
              <p class="text-xs text-gray-500 mt-0.5"><%= user.email %> · Joined <%= time_ago_in_words(user.created_at) %> ago</p>
            </div>
            <% if user.admin? %>
              <span class="text-xs px-2 py-0.5 rounded-full bg-gray-100 text-gray-600 font-medium">admin</span>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>

    <%# Recently added songs %>
    <div class="md:col-span-2">
      <h2 class="text-base font-semibold text-heading mb-3">Recently Added Songs</h2>
      <div class="divide-y divide-border border border-border rounded-xl overflow-hidden">
        <% @recent_songs.each do |song| %>
          <div class="px-4 py-3 bg-white flex items-center justify-between gap-3">
            <div class="min-w-0 flex items-center gap-3">
              <span class="text-lg font-bold text-heading font-logo shrink-0"><%= song.start_letter %></span>
              <div class="min-w-0">
                <p class="text-sm text-gray-700 truncate">
                  <%= song.movie.presence || "—" %>
                  <% if song.year.present? %><span class="text-gray-400">· <%= song.year %></span><% end %>
                </p>
                <p class="text-xs text-gray-500 mt-0.5">Added <%= time_ago_in_words(song.created_at) %> ago<% if song.user.present? %> by <%= song.user.username %><% end %></p>
              </div>
            </div>
            <%= link_to "View →", song_path(song), class: "text-xs text-gray-600 hover:text-gray-900 shrink-0" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
