<div id="comment-<%= comment.id %>" class="flex flex-col gap-1">
  <div class="flex items-center gap-2">
    <span class="text-sm font-medium text-gray-800"><%= comment.user.username %></span>
    <% if comment.user.admin? && comment.user != edit_log.song.user && comment.user != edit_log.user %>
      <span class="text-xs font-semibold px-1.5 py-0.5 rounded bg-gray-100 text-gray-600">Admin</span>
    <% elsif comment.user == edit_log.song.user %>
      <span class="text-xs font-semibold px-1.5 py-0.5 rounded bg-blue-100 text-blue-700">Creator</span>
    <% elsif comment.user == edit_log.user %>
      <span class="text-xs font-semibold px-1.5 py-0.5 rounded bg-violet-100 text-violet-700">Suggester</span>
    <% end %>
    <span class="text-xs text-gray-400"><%= time_ago_in_words(comment.created_at) %> ago</span>
  </div>
  <p class="text-sm text-gray-700 whitespace-pre-wrap"><%= comment.body %></p>
</div>
