<% content_for :title, "Showing song" %>

<div class="w-full">
  <div class="md:w-2/3">
    <div class="flex items-center justify-between mb-4">
      <%= link_to songs_path, class: "inline-flex items-center gap-1 text-sm text-gray-500 hover:text-gray-800" do %>
        &larr; Back to songs
      <% end %>
      <% if policy(@song).update? || policy(@song).destroy? %>
        <div class="flex items-center gap-2">
          <% if policy(@song).update? %>
            <%= link_to edit_song_path(@song), class: "p-1 rounded hover:bg-gray-200" do %>
              <%= image_tag "edit.svg", class: "w-5 h-5", alt: "Edit" %>
            <% end %>
          <% end %>
          <% if policy(@song).destroy? %>
            <%= button_to @song, method: :delete, class: "p-1 rounded hover:bg-gray-200 cursor-pointer", data: { turbo_confirm: "Are you sure?" } do %>
              <%= image_tag "trash.svg", class: "w-5 h-5", alt: "Destroy" %>
            <% end %>
          <% end %>
        </div>
      <% end %>
    </div>

    <%= render @song %>

    <div class="mt-4 flex items-center gap-3">
      <%= render "like_button", song: @song %>
      <div data-controller="clipboard" data-clipboard-text-value="<%= @song.lyrics %>">
        <button data-action="click->clipboard#copy"
                class="inline-flex items-center gap-1.5 text-xs text-gray-600 border border-gray-300 hover:border-gray-400 hover:text-gray-800 px-2.5 py-1 rounded-md hover:bg-gray-50 transition-colors cursor-pointer">
          <%= image_tag "clipboard.svg", class: "w-3.5 h-3.5", alt: "Copy" %>
          Copy lyrics
        </button>
      </div>
    </div>

    <div class="mt-6 pt-5 border-t border-border">
      <% pending_count = @song.edit_logs.pending.count %>
      <% if policy(@song).update? %>
        <% if pending_count > 0 %>
          <%= link_to song_edit_logs_path(@song), class: "inline-flex items-center gap-2 text-sm font-medium text-amber-700 hover:text-amber-900" do %>
            <span class="inline-flex items-center justify-center w-5 h-5 rounded-full bg-amber-100 text-amber-700 text-xs font-bold"><%= pending_count %></span>
            <%= pluralize(pending_count, "pending edit suggestion") %>
          <% end %>
        <% else %>
          <p class="text-sm text-gray-400">No pending edit suggestions.</p>
        <% end %>
      <% elsif policy(@song).suggest_edit? %>
        <p class="text-sm text-gray-500 mb-2">Suggest an edit:</p>
        <div class="flex flex-wrap gap-2">
          <% EditLog::FIELDS.each do |field| %>
            <% if (existing = @my_pending_edits[field]) %>
              <%= link_to song_edit_log_path(@song, existing),
                    class: "text-sm px-3 py-1 rounded-md border border-amber-300 bg-amber-50 text-amber-700 hover:bg-amber-100 transition-colors inline-flex items-center gap-1" do %>
                <%= field.capitalize %>
                <span class="text-xs font-medium">· pending</span>
              <% end %>
            <% else %>
              <%= link_to field.capitalize, new_song_edit_log_path(@song, field: field),
                    class: "text-sm px-3 py-1 rounded-md border border-gray-300 text-gray-600 hover:bg-gray-100 transition-colors" %>
            <% end %>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>

  <% if @related_songs.any? %>
    <h2 class="font-bold text-2xl text-heading mt-10 mb-4">More songs starting with "<%= @song.start_letter %>"</h2>
    <div class="grid gap-5" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr))">
      <% @related_songs.each do |song| %>
        <%= render "song_card", song: song, match: nil %>
      <% end %>
    </div>
  <% end %>
</div>
