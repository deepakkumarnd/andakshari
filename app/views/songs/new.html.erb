<% content_for :title, "New song" %>

<div class="md:w-2/3 w-full">
  <%= link_to songs_path, class: "inline-flex items-center gap-1 text-sm text-gray-500 hover:text-gray-800 mb-4" do %>
    &larr; Back to songs
  <% end %>

  <h1 class="font-bold text-4xl text-heading">New song</h1>

  <%= render "form", song: @song %>

  <%= link_to "Back to songs", songs_path, class: "w-full sm:w-auto text-center mt-2 sm:mt-0 sm:ml-2 rounded-md px-3.5 py-2.5 bg-gray-100 hover:bg-gray-50 inline-block font-medium" %>
</div>
