<div class="relative border border-border rounded-2xl p-4 w-full bg-gray-50 flex flex-col <%= match&.dig(:top_result) ? 'ring-2 ring-gray-500' : '' %>">
  <% if policy(song).update? || policy(song).destroy? %>
    <div class="absolute top-2 right-2 flex gap-1">
      <% if policy(song).update? %>
        <%= link_to edit_song_path(song), class: "p-1 rounded hover:bg-gray-300", data: { turbo_frame: "_top" } do %>
          <%= image_tag "edit.svg", class: "w-4 h-4", alt: "Edit" %>
        <% end %>
      <% end %>
      <% if policy(song).destroy? %>
        <%= button_to song, method: :delete, class: "p-1 rounded hover:bg-gray-300 cursor-pointer", data: { turbo_confirm: "Are you sure?" } do %>
          <%= image_tag "trash.svg", class: "w-4 h-4", alt: "Destroy" %>
        <% end %>
      <% end %>
    </div>
  <% end %>
  <% if match %>
    <p class="text-xs text-gray-500 mb-2">
      <%= match[:match] %>% match
      <% if match[:top_result] %><span class="ml-1 text-gray-700 font-semibold">Top result</span><% end %>
    </p>
  <% end %>
  <%= link_to song_path(song), class: "flex-1", data: { turbo_frame: "_top" } do %>
    <p class="text-2xl font-bold mb-2 text-heading font-logo"><%= song.start_letter %></p>
    <div class="prose prose-sm max-w-none text-letter font-malayalam overflow-hidden line-clamp-5">
      <%= format_song(song.pallavi) %>
    </div>
  <% end %>
  <% if song.tags.any? %>
    <div class="flex flex-wrap gap-1 mt-2">
      <% song.tags.each do |tag| %>
        <%= link_to tag.name, search_by_tag_songs_path(tag: tag.name), class: "text-xs bg-gray-200 text-gray-600 px-2 py-0.5 rounded-md hover:bg-gray-300 transition-colors", data: { turbo_frame: "_top" } %>
      <% end %>
    </div>
  <% end %>
  <div class="flex items-center justify-between mt-auto pt-3">
    <p class="text-sm text-letter-light">
      <%= [song.movie.presence, song.year.presence].compact.join(" · ") %>
    </p>
    <%= render "like_button", song: song %>
  </div>
</div>
