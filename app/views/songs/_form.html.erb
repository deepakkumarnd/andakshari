<%= form_with(model: song, class: "contents") do |form| %>
  <% if song.errors.any? %>
    <div id="error_explanation" class="bg-red-50 text-red-500 px-3 py-2 font-medium rounded-md mt-3">
      <h2><%= pluralize(song.errors.count, "error") %> prohibited this song from being saved:</h2>

      <ul class="list-disc ml-6">
        <% song.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="my-5">
    <%= form.label :lyrics %>
    <%= form.textarea :lyrics, rows: 4, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-gray-600": song.errors[:lyrics].none?, "border-red-400 focus:outline-red-600": song.errors[:lyrics].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :movie %>
    <%= form.text_field :movie, rows: 4, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-gray-600": song.errors[:movie].none?, "border-red-400 focus:outline-red-600": song.errors[:movie].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :year %>
    <%= form.number_field :year, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-gray-600": song.errors[:year].none?, "border-red-400 focus:outline-red-600": song.errors[:year].any?}] %>
  </div>

  <div class="inline">
    <%= form.submit class: "w-full sm:w-auto rounded-md px-3.5 py-2.5 bg-gray-700 hover:bg-gray-600 text-white inline-block font-medium cursor-pointer" %>
  </div>
<% end %>
