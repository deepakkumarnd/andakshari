<%= form_with url: search_songs_path, method: :post, data: { turbo_stream: true }, class: "flex items-center gap-2 mb-6 w-full max-w-2xl mx-auto" do |f| %>
  <%= f.search_field :q, placeholder: "Search songs...", class: "w-full rounded-md border border-gray-300 px-4 py-3 text-lg focus:outline-gray-500" %>
  <button type="submit" class="p-3 rounded-md bg-gray-700 hover:bg-gray-600 text-white flex-shrink-0">
    <%= image_tag "search.svg", class: "w-6 h-6 invert", alt: "Search" %>
  </button>
  <%= link_to songs_path, class: "p-3 rounded-md bg-gray-200 hover:bg-gray-300 flex-shrink-0", title: "Clear search" do %>
    <%= image_tag "x-mark.svg", class: "w-6 h-6", alt: "Clear" %>
  <% end %>
<% end %>
