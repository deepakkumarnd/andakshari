<%= turbo_stream.update "search_suggestions" do %>
  <% if @suggestions.any? %>
    <% @suggestions.each do |suggestion| %>
      <li>
        <%= link_to song_path(suggestion[:id]), class: "block px-4 py-3 hover:bg-gray-100 cursor-pointer", data: { turbo_frame: "_top" } do %>
          <span class="text-lg font-bold font-logo text-heading"><%= suggestion[:start_letter] %></span>
          <span class="text-sm text-gray-700 ml-2 font-malayalam"><%= suggestion[:pallavi] %></span>
          <% if suggestion[:movie].present? %>
            <span class="text-xs text-gray-400 ml-2"><%= suggestion[:movie] %></span>
          <% end %>
        <% end %>
      </li>
    <% end %>
  <% end %>
<% end %>
