<% content_for :title, "Songs" %>

<div class="w-full">
  <% if notice.present? %>
    <p class="py-2 px-3 bg-green-50 mb-5 text-green-500 font-medium rounded-md inline-block" id="notice"><%= notice %></p>
  <% end %>

  <div class="flex justify-between items-center">
    <h1 class="font-bold text-4xl">Songs</h1>
    <%= link_to "New song", new_song_path, class: "rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white block font-medium" %>
  </div>

  <div class="overflow-x-auto mt-5">
    <div id="songs" class="min-w-full flex gap-5">
      <% if @songs.any? %>
        <% @songs.each do |song| %>
            <div class="relative border rounded-md p-4 w-[300px] bg-gray-200">
              <div class="absolute top-2 right-2 flex gap-1">
                <%= link_to edit_song_path(song), class: "p-1 rounded hover:bg-gray-300" do %>
                  <%= image_tag "edit.svg", class: "w-4 h-4", alt: "Edit" %>
                <% end %>
                <%= button_to song, method: :delete, class: "p-1 rounded hover:bg-gray-300 cursor-pointer", data: { turbo_confirm: "Are you sure?" } do %>
                  <%= image_tag "trash.svg", class: "w-4 h-4", alt: "Destroy" %>
                <% end %>
              </div>
              <%= link_to song_path(song) do %>
                <p class="text-4xl font-bold mb-2"><%= song.letter %></p>
                <div>
                  <strong class="block font-medium mb-1">Pallavi:</strong>
                  <%= format_song(song.pallavi) %>
                </div>
              <% end %>
            </div>
        <% end %>
      <% else %>
        <p class="text-center my-10">No songs found.</p>
      <% end %>
    </div>
  </div>
</div>
