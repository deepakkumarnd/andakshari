<% content_for :title, "Pending edit suggestions" %>

<div class="w-full md:w-2/3">
  <%= link_to song_path(@song), class: "inline-flex items-center gap-1 text-sm text-gray-500 hover:text-gray-800 mb-6 block" do %>
    &larr; Back to song
  <% end %>

  <h1 class="font-bold text-3xl text-heading mb-6">Pending edit suggestions</h1>

  <% if @edit_logs.empty? %>
    <p class="text-gray-500 mt-4">No pending suggestions for this song.</p>
  <% else %>
    <div class="flex flex-col gap-4">
      <% @edit_logs.each do |edit_log| %>
        <div class="border border-border rounded-2xl p-5 bg-gray-50 flex flex-col gap-3">
          <div class="flex items-center gap-2">
            <span class="text-xs font-semibold uppercase tracking-wide text-gray-500 bg-gray-200 px-2 py-0.5 rounded-md"><%= edit_log.field %></span>
            <span class="text-sm text-gray-500">by <%= edit_log.user.email %></span>
            <span class="text-xs text-gray-400"><%= time_ago_in_words(edit_log.created_at) %> ago</span>
          </div>

          <% if edit_log.field == "lyrics" %>
            <div class="text-sm">
              <p class="text-xs font-medium text-gray-500 mb-1">Diff preview</p>
              <div class="max-h-32 overflow-hidden relative rounded-md">
                <%= lyrics_diff_html(edit_log.old_value, edit_log.new_value) %>
                <div class="absolute bottom-0 inset-x-0 h-8 bg-gradient-to-t from-gray-50 to-transparent pointer-events-none"></div>
              </div>
            </div>
          <% else %>
            <div class="grid grid-cols-2 gap-3 text-sm">
              <div>
                <p class="text-xs font-medium text-gray-500 mb-1">Old value</p>
                <div class="bg-red-50 border border-red-200 rounded-md px-3 py-2 text-gray-700 font-malayalam line-clamp-3"><%= edit_log.old_value.presence || "(blank)" %></div>
              </div>
              <div>
                <p class="text-xs font-medium text-gray-500 mb-1">Suggested value</p>
                <div class="bg-green-50 border border-green-200 rounded-md px-3 py-2 text-gray-700 font-malayalam line-clamp-3"><%= edit_log.new_value %></div>
              </div>
            </div>
          <% end %>

          <div class="flex items-center justify-between">
            <%= link_to edit_log.field == "lyrics" ? "View full diff →" : "View →",
                  song_edit_log_path(@song, edit_log),
                  class: "text-sm text-gray-600 hover:text-gray-900" %>
            <div class="flex gap-2">
              <%= button_to "Approve", approve_song_edit_log_path(@song, edit_log),
                    method: :post,
                    class: "px-3 py-1.5 rounded-md bg-gray-700 hover:bg-gray-600 text-white text-sm font-medium cursor-pointer" %>
              <%= button_to "Reject", reject_song_edit_log_path(@song, edit_log),
                    method: :post,
                    class: "px-3 py-1.5 rounded-md bg-white hover:bg-gray-100 text-gray-700 text-sm font-medium border border-gray-300 cursor-pointer" %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
