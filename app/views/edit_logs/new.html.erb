<% content_for :title, "Suggest an edit" %>

<div class="w-full md:w-2/3">
  <%= link_to song_path(@song), class: "inline-flex items-center gap-1 text-sm text-gray-500 hover:text-gray-800 mb-6 block" do %>
    &larr; Back to song
  <% end %>

  <h1 class="font-bold text-3xl text-heading mb-2">Suggest a change</h1>
  <p class="text-gray-500 mb-6">Suggesting an edit to <strong><%= @edit_log.field %></strong>. The song creator will review your suggestion before it is applied.</p>

  <%= render "form", song: @song, edit_log: @edit_log, submit_label: "Submit suggestion" %>
</div>
