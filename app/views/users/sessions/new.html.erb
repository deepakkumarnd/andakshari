<% content_for :title, "Sign in" %>

<div class="w-full max-w-md mx-auto mt-10">
  <div class="border border-border rounded-2xl p-8 bg-gray-50">
    <h1 class="text-3xl font-bold text-heading mb-6 text-center font-logo">Sign In</h1>

    <% if @step == :otp %>
      <%= form_with url: user_session_path, method: :post, class: "space-y-5" do |f| %>
        <p class="text-sm text-gray-500">We sent a 6-digit code to <strong><%= @email %></strong></p>
        <%= hidden_field_tag :email, @email %>
        <div>
          <label for="otp_code" class="block text-sm font-medium text-gray-700 mb-1">Enter code</label>
          <input type="text" name="otp_code" id="otp_code" inputmode="numeric" autocomplete="one-time-code"
                 maxlength="6" placeholder="000000" autofocus
                 class="block w-full rounded-md border border-gray-400 px-4 py-3 text-lg text-center tracking-widest focus:outline-gray-600" />
        </div>
        <button type="submit" class="w-full rounded-md px-3.5 py-2.5 bg-gray-700 hover:bg-gray-600 text-white font-medium cursor-pointer">
          Verify & Sign In
        </button>
      <% end %>
      <p class="text-sm text-gray-500 mt-4 text-center">
        <%= link_to "Use a different email", new_user_session_path, class: "text-gray-700 underline hover:text-gray-900" %>
      </p>
    <% else %>
      <%= form_with url: user_session_path, method: :post, class: "space-y-5" do |f| %>
        <div>
          <label for="user_email" class="block text-sm font-medium text-gray-700 mb-1">Email address</label>
          <input type="email" name="user[email]" id="user_email" autofocus autocomplete="email"
                 class="block w-full rounded-md border border-gray-400 px-4 py-3 text-lg focus:outline-gray-600"
                 placeholder="you@example.com" />
        </div>
        <button type="submit" class="w-full rounded-md px-3.5 py-2.5 bg-gray-700 hover:bg-gray-600 text-white font-medium cursor-pointer">
          Send Login Code
        </button>
      <% end %>
      <p class="text-sm text-gray-500 mt-4 text-center">
        Don't have an account?
        <%= link_to "Register", new_user_registration_path, class: "text-gray-700 underline hover:text-gray-900" %>
      </p>
    <% end %>
  </div>
</div>
